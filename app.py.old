import streamlit as st
from config.database import db
from config.settings import settings
from utils.auth import Auth
from models.user import UserModel

# Page configuration
st.set_page_config(
    page_title=settings.APP_NAME,
    page_icon="🎥",
    layout="wide",
    initial_sidebar_state="expanded"
)

# Initialize database connection
if 'db_connected' not in st.session_state:
    st.session_state.db_connected = db.connect()

# Initialize session state
if 'user' not in st.session_state:
    st.session_state.user = None

# Custom CSS
st.markdown("""
<style>
    .main-header {
        font-size: 2.5rem;
        font-weight: bold;
        color: #FF0000;
        text-align: center;
        margin-bottom: 2rem;
    }
    .metric-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 20px;
        border-radius: 10px;
        color: white;
        text-align: center;
    }
    .video-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 15px;
        margin: 10px 0;
        transition: transform 0.2s;
    }
    .video-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }
</style>
""", unsafe_allow_html=True)

# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

def display_recent_videos():
    """Display recent videos"""
    from models.video import VideoModel
    from utils.helpers import Helpers
    
    video_model = VideoModel()
    videos = video_model.get_all(limit=6)
    
    if videos:
        cols = st.columns(3)
        for idx, video in enumerate(videos):
            with cols[idx % 3]:
                st.image(video.get('thumbnail', 'https://via.placeholder.com/300x200'), use_column_width=True)
                st.markdown(f"**{video['title']}**")
                st.caption(f"👁️ {Helpers.format_number(video.get('views', 0))} views")
                st.caption(f"📅 {Helpers.time_ago(video.get('created_at'))}")
    else:
        st.info("No videos available yet.")

def display_public_home():
    """Display public home page"""
    st.info("👋 Welcome to YouTube Media System! Please login or register to continue.")
    
    st.markdown("### 🚀 Get Started")
    col1, col2 = st.columns(2)
    
    with col1:
        st.markdown("#### 🔐 Existing User?")
        st.info("Use the sidebar to navigate to the **Login** page")
    
    with col2:
        st.markdown("#### 📝 New User?")
        st.info("Use the sidebar to navigate to the **Register** page")
    
    st.markdown("---")
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.markdown("### 🎬 Features")
        st.markdown("""
        - 📺 Create and manage channels
        - 🎥 Upload and manage videos
        - 📋 Create playlists
        - 💬 Comment and engage
        - 📊 View analytics
        - 🔍 Advanced search
        """)
    
    with col2:
        st.markdown("### 👥 User Roles")
        st.markdown("""
        - **Admin**: Full system control
        - **Creator**: Create content
        - **Viewer**: Watch and engage
        """)
    
    # Display recent videos
    st.markdown("### 🔥 Recent Videos")
    display_recent_videos()

def display_admin_dashboard():
    """Admin dashboard"""
    st.markdown("## 👑 Admin Dashboard")
    
    database = db.get_db()
    
    # Metrics
    col1, col2, col3, col4 = st.columns(4)
    
    with col1:
        total_users = database.users.count_documents({})
        st.metric("👥 Total Users", total_users)
    
    with col2:
        total_channels = database.channels.count_documents({})
        st.metric("📺 Total Channels", total_channels)
    
    with col3:
        total_videos = database.videos.count_documents({})
        st.metric("🎥 Total Videos", total_videos)
    
    with col4:
        total_comments = database.comments.count_documents({})
        st.metric("💬 Total Comments", total_comments)
    
    st.markdown("---")
    
    # Charts
    col1, col2 = st.columns(2)
    
    with col1:
        st.markdown("### 📊 Users by Role")
        role_counts = {}
        for role in [settings.ROLE_ADMIN, settings.ROLE_CREATOR, settings.ROLE_VIEWER]:
            count = database.users.count_documents({"role": role})
            role_counts[role] = count
        
        import plotly.graph_objects as go
        fig = go.Figure(data=[go.Pie(labels=list(role_counts.keys()), values=list(role_counts.values()))])
        fig.update_layout(height=300)
        st.plotly_chart(fig, use_container_width=True)
    
    with col2:
        st.markdown("### 📈 Content Overview")
        st.metric("Total Channels", total_channels)
        st.metric("Total Videos", total_videos)
        st.metric("Total Comments", total_comments)
        
    # Recent activity
    st.markdown("### 📋 Recent Activity")
    
    recent_users = list(database.users.find().sort("created_at", -1).limit(5))
    if recent_users:
        for user in recent_users:
            st.caption(f"👤 New user: **{user['username']}** ({user['role']}) - {user['created_at'].strftime('%Y-%m-%d %H:%M')}")
    else:
        st.info("No recent activity")

def display_creator_dashboard():
    """Creator dashboard"""
    st.markdown("## 🎨 Creator Dashboard")
    
    user = Auth.get_current_user()
    user_model = UserModel()
    stats = user_model.get_user_stats(str(user['_id']))
    
    # Metrics
    col1, col2, col3, col4 = st.columns(4)
    
    with col1:
        st.metric("📺 My Channels", stats['channels'])
    
    with col2:
        st.metric("🎥 My Videos", stats['videos'])
    
    with col3:
        st.metric("👁️ Total Views", stats['total_views'])
    
    with col4:
        st.metric("📋 My Playlists", stats['playlists'])
    
    st.markdown("---")
    
    # Quick actions
    st.markdown("### ⚡ Quick Actions")
    st.info("👈 Use the **sidebar navigation** to access:")
    
    col1, col2, col3 = st.columns(3)
    
    with col1:
        st.markdown("**📺 Channel Management**")
        st.caption("Create and manage your channels")
    
    with col2:
        st.markdown("**🎬 Video Management**")
        st.caption("Upload and edit videos")
    
    with col3:
        st.markdown("**📊 Analytics**")
        st.caption("View your performance")
    
    st.markdown("---")
    
    # Recent videos
    st.markdown("### 🎥 My Recent Videos")
    from models.video import VideoModel
    from utils.helpers import Helpers
    video_model = VideoModel()
    my_videos = video_model.get_by_creator(str(user['_id']))
    
    if my_videos:
        for video in my_videos[:5]:
            col1, col2 = st.columns([1, 3])
            
            with col1:
                st.image(video.get('thumbnail', 'https://via.placeholder.com/200x120'), use_column_width=True)
            
            with col2:
                st.markdown(f"**{video['title']}**")
                st.caption(f"👁️ {Helpers.format_number(video.get('views', 0))} views • "
                          f"👍 {Helpers.format_number(video.get('likes', 0))} likes")
    else:
        st.info("No videos yet. Upload your first video!")

def display_viewer_dashboard():
    """Viewer dashboard"""
    st.markdown("## 👀 Viewer Dashboard")
    
    # Display trending videos
    st.markdown("### 🔥 Trending Videos")
    display_recent_videos()
    
    st.markdown("---")
    
    # Browse channels
    st.markdown("### 📺 Popular Channels")
    from models.channel import ChannelModel
    channel_model = ChannelModel()
    channels = channel_model.get_all(limit=6)
    
    if channels:
        cols = st.columns(3)
        for idx, channel in enumerate(channels):
            with cols[idx % 3]:
                st.markdown(f"**📺 {channel['channel_name']}**")
                st.caption(f"👥 {channel.get('subscribers', 0)} subscribers")
                st.caption(f"by {channel.get('creator_name', 'Unknown')}")
    else:
        st.info("No channels available yet")

def initialize_default_admin():
    """Create default admin user if not exists"""
    database = db.get_db()
    admin_exists = database.users.find_one({"username": "admin"})
    
    if not admin_exists:
        from utils.auth import Auth
        Auth.register("admin", "admin@system.com", "admin123", settings.ROLE_ADMIN)

# ============================================================================
# MAIN APPLICATION
# ============================================================================

def main():
    """Main application"""
    
    # Sidebar
    with st.sidebar:
        st.image("https://via.placeholder.com/150x50?text=YouTube+Media", use_column_width=True)
        st.markdown("---")
        
        if Auth.is_authenticated():
            user = Auth.get_current_user()
            st.success(f"👤 {user['username']}")
            st.caption(f"Role: {user['role']}")
            
            if st.button("🚪 Logout", use_container_width=True):
                Auth.logout()
                st.rerun()
        else:
            st.info("Please login to continue")
            st.caption("Use the sidebar pages to:")
            st.caption("• Login to existing account")
            st.caption("• Register new account")
        
        st.markdown("---")
        st.markdown("### 📊 Quick Stats")
        
        # Display quick stats
        try:
            database = db.get_db()
            total_users = database.users.count_documents({})
            total_videos = database.videos.count_documents({})
            total_channels = database.channels.count_documents({})
            
            st.metric("Total Users", total_users)
            st.metric("Total Videos", total_videos)
            st.metric("Total Channels", total_channels)
        except:
            st.caption("Stats unavailable")
    
    # Main content
    st.markdown('<div class="main-header">🎥 YouTube Media Management System</div>', unsafe_allow_html=True)
    
    if not st.session_state.db_connected:
        st.error("❌ Failed to connect to database. Please check your MongoDB connection.")
        st.info("💡 Make sure MongoDB is running and the connection string in .env is correct.")
        return
    
    # Welcome message
    if Auth.is_authenticated():
        user = Auth.get_current_user()
        st.success(f"Welcome back, **{user['username']}**! 👋")
        
        # Role-specific dashboard
        if user['role'] == settings.ROLE_ADMIN:
            display_admin_dashboard()
        elif user['role'] == settings.ROLE_CREATOR:
            display_creator_dashboard()
        else:
            display_viewer_dashboard()
    else:
        display_public_home()

# Run initialization
if st.session_state.db_connected:
    initialize_default_admin()

if __name__ == "__main__":
    main()